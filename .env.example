# Copy to .env.local and fill in real values. Never commit .env.local.

# Apify, Google Maps + Instagram scraping
APIFY_TOKEN=
APIFY_ORG_ID=

# Resend, quarterly issue emails + claim verification
RESEND_API_KEY=

# Anthropic, scoring + editorial draft generation
ANTHROPIC_API_KEY=

# Neon Postgres, primary datastore for businesses, scores, analyses, leads.
# Provision via the Vercel Marketplace (Storage tab) and paste the pooled
# connection string here. Docs: https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# PostHog, product analytics + conversion dashboard.
# Project API key (starts with phc_) from the Signal Pittsburgh PostHog
# account: Settings > Project > API key. Safe to expose client-side.
NEXT_PUBLIC_POSTHOG_KEY=
# UI host for links back to PostHog. US: https://us.posthog.com (default),
# EU: https://eu.posthog.com. If EU, also update the /ingest destinations in
# next.config.ts.
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
