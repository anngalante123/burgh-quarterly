# Copy to .env.local and fill in real values. Never commit .env.local.

# Apify, Google Maps + Instagram scraping
APIFY_TOKEN=
APIFY_ORG_ID=

# Resend, quarterly issue emails + claim verification
RESEND_API_KEY=

# Anthropic, scoring + editorial draft generation
ANTHROPIC_API_KEY=

# Neon Postgres, primary datastore for businesses, scores, analyses, leads.
# Provision via the Vercel Marketplace (Storage tab) and paste the pooled
# connection string here. Docs: https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
